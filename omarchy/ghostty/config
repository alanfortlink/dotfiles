# Dynamic theme colors from omarchy (overrides hardcoded theme below)
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

font-family = PragmataPro Mono Liga
font-style = Regular
font-thicken = true
font-size = 12

background = "#000000"
background-opacity = 0.8
background-blur-radius = 100
macos-titlebar-style = tabs
theme = "3024 Night"

# All opt+/M- pane and split bindings are owned by tmux (see ~/.tmux.conf).
# Only non-conflicting clipboard binds remain here.
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard

# --- Copy/scroll mode (tmux copy-mode-vi analogue) ---
# alt+u / alt+d enter the "copy" key table and scroll one page.
keybind = alt+u=activate_key_table:copy
keybind = chain=scroll_page_up
keybind = alt+d=activate_key_table:copy
keybind = chain=scroll_page_down

# Inside copy mode: scroll/navigate, select, copy, exit.
keybind = copy/u=scroll_page_up
keybind = copy/d=scroll_page_down
keybind = copy/g=scroll_to_top
keybind = copy/shift+g=scroll_to_bottom
# Selection: v starts/extends a selection; hjkl adjust it.
# (ghostty has no scrollback cursor, so v alone may be a no-op without
#  an existing selection — extend with hjkl after starting a mouse drag,
#  or use shift+arrow which works the same way.)
keybind = copy/v=adjust_selection:right
keybind = copy/h=adjust_selection:left
keybind = copy/j=adjust_selection:down
keybind = copy/k=adjust_selection:up
keybind = copy/l=adjust_selection:right
keybind = copy/y=copy_to_clipboard
keybind = chain=deactivate_key_table
keybind = copy/escape=deactivate_key_table
keybind = copy/q=deactivate_key_table

window-save-state = "always"
shell-integration = "zsh"
confirm-close-surface = false
