#!/usr/bin/env bash
set -euo pipefail

# name=x1,y1,x2,y2  — cubic-bezier control points.
# Sine/Quad/Cubic/Quart/Quint/Expo/Circ from easings.net.
# Back* variants overshoot (closest cubic approximation of elastic).
# Hyprland beziers are single cubics, so true Elastic/Bounce can't be expressed.
curves=(
  "linear=0,0,1,1"
  "almostLinear=0.5,0.5,0.75,1"
  "quick=0.15,0,0.1,1"

  "easeInSine=0.12,0,0.39,0"
  "easeOutSine=0.61,1,0.88,1"
  "easeInOutSine=0.37,0,0.63,1"

  "easeInQuad=0.11,0,0.5,0"
  "easeOutQuad=0.5,1,0.89,1"
  "easeInOutQuad=0.45,0,0.55,1"

  "easeInCubic=0.32,0,0.67,0"
  "easeOutCubic=0.33,1,0.68,1"
  "easeInOutCubic=0.65,0,0.35,1"

  "easeInQuart=0.5,0,0.75,0"
  "easeOutQuart=0.25,1,0.5,1"
  "easeInOutQuart=0.76,0,0.24,1"

  "easeInQuint=0.64,0,0.78,0"
  "easeOutQuint=0.22,1,0.36,1"
  "easeInOutQuint=0.83,0,0.17,1"

  "easeInExpo=0.7,0,0.84,0"
  "easeOutExpo=0.16,1,0.3,1"
  "easeInOutExpo=0.87,0,0.13,1"

  "easeInCirc=0.55,0,1,0.45"
  "easeOutCirc=0,0.55,0.45,1"
  "easeInOutCirc=0.85,0,0.15,1"

  "easeInBack=0.36,0,0.66,-0.56"
  "easeOutBack=0.34,1.56,0.64,1"
  "easeInOutBack=0.68,-0.6,0.32,1.6"
)

state="${XDG_STATE_HOME:-$HOME/.local/state}/hypr-anim-curve"
mkdir -p "$(dirname "$state")"

idx=0
[[ -f "$state" ]] && idx=$(<"$state")

case "${1:-next}" in
  next) idx=$(( (idx + 1) % ${#curves[@]} )) ;;
  prev) idx=$(( (idx - 1 + ${#curves[@]}) % ${#curves[@]} )) ;;
  pick)
    chosen=$(printf '%s\n' "${curves[@]%%=*}" | walker --dmenu -p "Animation curve" -c "$idx") || exit 0
    [[ -z "$chosen" ]] && exit 0
    for i in "${!curves[@]}"; do
      [[ ${curves[$i]%%=*} == "$chosen" ]] && idx=$i && break
    done
    ;;
  *) echo "usage: $0 [next|prev|pick]" >&2; exit 2 ;;
esac

entry=${curves[$idx]}
name=${entry%%=*}
points=${entry#*=}
echo "$idx" > "$state"

hyprctl --batch "\
  keyword bezier $name,$points ; \
  keyword animation windows,1,3.79,$name ; \
  keyword animation windowsIn,1,4.1,$name,popin 87% ; \
  keyword animation windowsOut,1,1.49,$name,popin 87%" >/dev/null

notify-send -t 1500 -h string:x-canonical-private-synchronous:anim-curve \
  "Window animation" "$name"
