#!/bin/bash
# Sync the live system config from $HOME into this repo.
# Run from anywhere; the repo location is derived from this script's path.
set -euo pipefail

REPO="$(cd "$(dirname "$0")" && pwd)"

# ~/.config/<dir>  ->  repo/omarchy/<dir>
CONFIG_DIRS=(
  alacritty
  btop
  fastfetch
  ghostty
  hypr
  kitty
  lazygit
  mako
  swayosd
  walker
  waybar
)

# ~/.config/<file>  ->  repo/omarchy/<file>
CONFIG_FILES=(
  starship.toml
)

# ~/.local/bin/<script>  ->  repo/omarchy/bin/<script>
BIN_SCRIPTS=(
  codex
  copilot
  gemini
  ghui
  mac-shortcut
  opencode
  pi
  playwright-cli
  quit-app
  session-restore
  session-save
  weather-icon-temp
  web-search
)

# ~/<file>  ->  repo/<file>
HOME_FILES=(
  .aliases
  .bashrc
  .tmux.conf
)

RSYNC_EXCLUDES=(
  --exclude='*.bak*'
  --exclude='*.bak.*'
  --exclude='config.bak-*'
)

mkdir -p "$REPO/omarchy/bin"

for d in "${CONFIG_DIRS[@]}"; do
  src="$HOME/.config/$d"
  dst="$REPO/omarchy/$d"
  if [ -d "$src" ]; then
    mkdir -p "$dst"
    rsync -a --delete "${RSYNC_EXCLUDES[@]}" "$src/" "$dst/"
    echo "  config/$d"
  fi
done

for f in "${CONFIG_FILES[@]}"; do
  src="$HOME/.config/$f"
  dst="$REPO/omarchy/$f"
  if [ -f "$src" ] && ! [ "$src" -ef "$dst" ]; then
    cp "$src" "$dst"
    echo "  config/$f"
  fi
done

for s in "${BIN_SCRIPTS[@]}"; do
  src="$HOME/.local/bin/$s"
  dst="$REPO/omarchy/bin/$s"
  if [ -f "$src" ] && ! [ "$src" -ef "$dst" ]; then
    cp "$src" "$dst"
    echo "  bin/$s"
  fi
done

for f in "${HOME_FILES[@]}"; do
  src="$HOME/$f"
  dst="$REPO/$f"
  if [ -f "$src" ] && ! [ "$src" -ef "$dst" ]; then
    cp "$src" "$dst"
    echo "  $f"
  fi
done

# nvim: ~/.config/nvim  ->  repo/nvim
if [ -d "$HOME/.config/nvim" ]; then
  mkdir -p "$REPO/nvim"
  rsync -a --delete "${RSYNC_EXCLUDES[@]}" "$HOME/.config/nvim/" "$REPO/nvim/"
  echo "  nvim/"
fi

# claude: only durable user content (no secrets, sessions, history, caches)
if [ -d "$HOME/.claude" ]; then
  mkdir -p "$REPO/claude"
  rsync -a --delete \
    --include='CLAUDE.md' \
    --include='settings.json' \
    --include='skills/***' \
    --include='agents/***' \
    --include='commands/***' \
    --exclude='*' \
    "$HOME/.claude/" "$REPO/claude/"
  echo "  claude/"
fi

echo
echo "Done. Review with: git -C \"$REPO\" status"
